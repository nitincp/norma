# Copy to .env and fill in values. Never commit .env.

# ── Langfuse ─────────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://langfuse-server:3000

# Langfuse self-hosted internals (generate with: openssl rand -base64 32)
LANGFUSE_NEXTAUTH_SECRET=change-me
LANGFUSE_SALT=change-me
LANGFUSE_DB_PASSWORD=langfuse

# ── LiteLLM ──────────────────────────────────────────────────────────────────
LITELLM_BASE_URL=http://litellm-gateway:4000
LITELLM_MASTER_KEY=sk-litellm-...

# ── Cloud API fallbacks (optional — Ollama is the default) ───────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://host-gateway:11434
OLLAMA_NUM_PARALLEL=1

# ── Norma runtime ─────────────────────────────────────────────────────────────
NORMA_DEFAULT_MODEL=local/qwen2.5-0.5b
NORMA_VALIDATION_MODEL=local/qwen2.5-0.5b
NORMA_DEEP_MODEL=local/phi3-mini
